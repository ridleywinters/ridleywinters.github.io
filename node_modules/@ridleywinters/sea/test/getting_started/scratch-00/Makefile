clean:
	rm -rf my-site
	rm -rf node_modules
	rm -rf dist
	rm -f package.json
	rm -f package-lock.json

#
# Rebuild and install sea from the current source
#
reset: clean
	echo {} > package.json
	make -C $(MONOREPO_ROOT)/source/html/sites/ridleywinters.github.io build
	cp $(MONOREPO_ROOT)/source/html/sites/ridleywinters.github.io/dist/client.bundle.js ../../../src/template/core/dist/client.bundle.js
	make -C ../../.. build
	npm i ../../..

init:
	npx sea init my-site

build:
	npx sea build my-site dist

upload:
	cd dist && curl -H "Authorization: Bearer $(NEOCITIES_API_KEY)" -F "index.html=@index.html" https://neocities.org/api/upload
	cd dist && curl -H "Authorization: Bearer $(NEOCITIES_API_KEY)" -F "dist/client.bundle.js=@dist/client.bundle.js" https://neocities.org/api/upload
	cd dist && curl -H "Authorization: Bearer $(NEOCITIES_API_KEY)" -F "database.json=@database.json" https://neocities.org/api/upload
go: reset init build upload

